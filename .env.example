# Database — required (Neon, Supabase, or any Postgres)
DATABASE_URL="postgresql://user:pass@host/db?sslmode=require"

# NextAuth — required
NEXTAUTH_URL="https://your-domain.com"
NEXTAUTH_SECRET="generate with: openssl rand -base64 32"

# App URL — used for OG metadata, sitemap
NEXT_PUBLIC_APP_URL="https://your-domain.com"
NEXT_PUBLIC_APP_NAME="WorkWhisper"

# Email (SMTP for OTP login) — required if you use email auth
SMTP_HOST="smtp.gmail.com"
SMTP_PORT="587"
SMTP_USER="you@gmail.com"
SMTP_PASS="app-specific-password"
EMAIL_FROM="WorkWhisper <you@gmail.com>"

# Pusher (Realtime updates) — optional, can leave blank
PUSHER_APP_ID=""
PUSHER_KEY=""
PUSHER_SECRET=""
PUSHER_CLUSTER="ap2"
NEXT_PUBLIC_PUSHER_KEY=""
NEXT_PUBLIC_PUSHER_CLUSTER="ap2"

# OpenAI (post moderation + insights) — optional
OPENAI_API_KEY=""
